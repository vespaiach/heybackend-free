{
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(touch:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(source:*)",
      "Bash(export:*)",
      "Bash(env:*)",
      "Bash(which:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(tar:*)",
      "Bash(gzip:*)",
      "Bash(gunzip:*)",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(killall:*)",
      "Bash(top:*)",
      "Bash(htop:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(ln:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(paste:*)",
      "Bash(diff:*)",
      "Bash(patch:*)",
      "Bash(test:*)",
      "Bash([ ]*)",
      "Bash(for:*)",
      "Bash(while:*)",
      "Bash(if:*)",
      "Bash(case:*)",
      "Bash(time:*)",
      "Bash(timeout:*)",
      "Bash(nohup:*)",
      "Bash(screen:*)",
      "Bash(tmux:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(sudo:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(whoami:*)",
      "Bash(groups:*)",
      "Bash(id:*)",
      "Bash(date:*)",
      "Bash(cal:*)",
      "Bash(history:*)",
      "Bash(clear:*)",
      "Bash(printenv:*)",
      "Bash(alias:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(man:*)",
      "WebFetch(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(/root/.ssh/**)",
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Read(/var/log/**)",
      "Bash(rm:/ *)",
      "Bash(rm:/* )",
      "Bash(chmod:000 /)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && npm run sort:import -- \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Sorting import statements..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && npm run format -- \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting file..."
          }
        ]
      }
    ]
  },
  "defaultMode": "default",
  "additionalDirectories": []
}
